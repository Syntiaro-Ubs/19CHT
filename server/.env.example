# Mail server (Nodemailer)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: override where emails are delivered
MAIL_TO=careerhubtechnologypimpri@gmail.com

# Optional: SMTP server settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Server settings
PORT=3001

# Optional: attach a PDF to outbound mails (relative to project root or absolute path)
# ATTACH_PDF_PATH=./public/brochure.pdf

# Optional: restrict CORS (comma-separated)
# CORS_ORIGIN=http://localhost:5173
